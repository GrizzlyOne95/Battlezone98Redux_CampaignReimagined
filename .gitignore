# Ignore everything in _Source root by default
/*

# Allow organized source folders
!/Assets/
!/Bin/
!/Config/
!/flags/
!/Materials/
!/Missions/
!/ODF/
!/OverlayFont/
!/References/
!/Scripts/
!/Shaders/
!/Text/
!/_Source/
!/_Source/Scripts/
!/_Source/Scripts/PersistentConfigD.lua
!/_Source/Scripts/PersistentConfigP.lua

# Intentional root files
!/.gitignore
!/AGENTS.md
!/CHANGELOG.md
!/Manage-CampaignFiles.ps1
!/README.md
!/install.des
!/nocopy.des

# Local machine/generated artifacts live under Local and stay ignored
/Local/

# Ignore system files
thumbs.db
desktop.ini

# Ignore specific generated files inside tracked folders
/Config/fix_locations.csv
/Text/need_defs.txt
/Text/OgreMain.dumpbin.exports.txt
