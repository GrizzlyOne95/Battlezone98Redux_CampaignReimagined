# Ignore unexpected runtime-flat root files by default
/*

# Allow source tree
!/_Source/

# Allow organized source folders
!/Assets/
!/Bin/
!/Config/
!/flags/
!/Materials/
!/Missions/
!/ODF/
!/OverlayFont/
!/References/
!/Scripts/
!/Shaders/
!/Text/

# Intentional root files
!/.gitignore
!/AGENTS.md
!/CHANGELOG.md
!/Manage-CampaignFiles.ps1
!/README.md
!/install/
!/install/install_windows.ps1
!/install.des
!/update.des
!/staged.des
!/nocopy.des

# Local machine/generated artifacts live under Local and stay ignored
/Local/

# Ignore system files
thumbs.db
desktop.ini

# Ignore specific generated files inside tracked folders
/Config/fix_locations.csv
/Text/need_defs.txt
/Text/OgreMain.dumpbin.exports.txt
