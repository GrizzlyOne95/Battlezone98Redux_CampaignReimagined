import * from "BZBase.material"

material testground : BZBase
{
	set_texture_alias DiffuseMap MOON_ATLAS_D.dds
	set_texture_alias NormalMap MOON_ATLAS_N.dds
	set_texture_alias SpecularMap abcomm_S.dds
	set_texture_alias EmissiveMap black.png

	set $diffuse "1 1 1"
	set $ambient "0.5 0.5 0.5"
	set $specular ".96 .86 .67"
	set $shininess "127"
}



