import * from "BZBase.material"

material iechunk5_BZBase_iechunks : BZBase
{
	set_texture_alias DiffuseMap iechunks.dds
	set_texture_alias NormalMap iechunks_n.dds
	set_texture_alias SpecularMap iechunks_s.dds
	set_texture_alias EmissiveMap iechunks_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $glow "1 1 1"
}


