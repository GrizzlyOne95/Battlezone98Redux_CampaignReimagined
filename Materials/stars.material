material STARS.MAP
{
	technique
	{
		pass
		{
			vertex_program_ref CR_Sky_vertex
			{
			}
			fragment_program_ref CR_Sky_fragment
			{
			} 

			cull_hardware none
			cull_software none 
			lighting off
			emissive 0 0 0
			fog_override true none
			scene_blend alpha_blend
			depth_write off
			diffuse vertexcolour
			texture_unit
			{
				tex_address_mode clamp
				texture stars.png
			}
		}
	}
}

